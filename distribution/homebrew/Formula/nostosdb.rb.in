# Candidate template only. Publication requires separate authorization.

class Nostosdb < Formula
  desc "Source-first property graph database CLI and local service"
  homepage "https://github.com/nostosdb/nostosdb-server"
  version "@VERSION@"
  license "SSPL-1.0"

  on_arm do
    url "@ARM64_URL@"
    sha256 "@ARM64_SHA256@"
  end

  on_intel do
    url "@X64_URL@"
    sha256 "@X64_SHA256@"
  end

  def install
    bin.install "nostos", "nostosd"
  end

  def caveats
    <<~EOS
      Initialize per-user state before starting the service:
        mkdir -p "$HOME/.nostosdb/data" "$HOME/.nostosdb/config" "$HOME/.nostosdb/logs"
        chmod 700 "$HOME/.nostosdb" "$HOME/.nostosdb/data" "$HOME/.nostosdb/config" "$HOME/.nostosdb/logs"
        #{opt_bin}/nostosd init \
          --data-dir "$HOME/.nostosdb/data" \
          --config "$HOME/.nostosdb/config/server.toml" \
          --listen 127.0.0.1:7878
        brew services start nostosdb

      Initialization is explicit because Homebrew runs post_install with a
      temporary HOME that is removed after installation.
    EOS
  end

  service do
    nostos_home = Pathname.new(Dir.home)/".nostosdb"
    run [opt_bin/"nostosd", "serve", "--config", (nostos_home/"config/server.toml").to_s]
    keep_alive true
    environment_variables NOSTOS_HOME: nostos_home.to_s
    log_path (nostos_home/"logs/nostosd.log").to_s
    error_log_path (nostos_home/"logs/nostosd.log").to_s
    working_dir nostos_home.to_s
  end

  test do
    assert_equal "nostos #{version}", shell_output("#{bin}/nostos --version").strip
    assert_equal "nostosd #{version}", shell_output("#{bin}/nostosd --version").strip
  end
end
